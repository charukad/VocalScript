# NeuralScribe optional LLM settings.
# Copy this file to .env and fill in your own values. Never commit real API keys.

# Free/local fallback. Valid values: rule_based, ollama, lm_studio, openai_compatible, local_server, openrouter, gemini.
NEURALSCRIBE_LLM_MODE=rule_based

# OpenRouter mode.
# Rotate any key that was pasted into chat, then put the new key here.
NEURALSCRIBE_OPENROUTER_API_KEY=replace-with-your-openrouter-key
NEURALSCRIBE_OPENROUTER_MODEL=google/gemma-4-31b-it:free
NEURALSCRIBE_OPENROUTER_REASONING=true
NEURALSCRIBE_OPENROUTER_SITE_URL=http://127.0.0.1:3000
NEURALSCRIBE_OPENROUTER_APP_NAME=NeuralScribe

# Google Gemini mode.
# The Google SDK reads GEMINI_API_KEY from the environment, and the backend also supports this variable.
GEMINI_API_KEY=replace-with-your-gemini-key
NEURALSCRIBE_GEMINI_MODEL=gemini-3-flash-preview

# Ollama mode.
NEURALSCRIBE_OLLAMA_URL=http://127.0.0.1:11434
NEURALSCRIBE_OLLAMA_MODEL=llama3.2:3b

# LM Studio / OpenAI-compatible local server mode.
NEURALSCRIBE_LOCAL_LLM_URL=http://127.0.0.1:1234/v1
NEURALSCRIBE_LOCAL_LLM_MODEL=local-model
